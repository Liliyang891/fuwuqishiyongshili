# === SSH 服务器配置 ===
SSH_HOST=your.server.ip
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=your_ssh_password
REMOTE_DIR=/root/fuwuqishiyongshili

# === AI 模型 Provider 1 ===
PROVIDER1_NAME=ModelName
PROVIDER1_API_URL=https://api.example.com/v1/chat/completions
PROVIDER1_API_KEY=sk-your-api-key
PROVIDER1_MODEL=model-name
PROVIDER1_MAX_TOKENS=4096
PROVIDER1_TEMPERATURE=0.7

# === AI 模型 Provider 2 (可选，留空则跳过) ===
PROVIDER2_NAME=
PROVIDER2_API_URL=
PROVIDER2_API_KEY=
PROVIDER2_MODEL=
PROVIDER2_MAX_TOKENS=4096
PROVIDER2_TEMPERATURE=0.7

# === 服务器设置 ===
SERVER_PORT=8888
CORS_ORIGIN=*
