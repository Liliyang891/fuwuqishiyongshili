# === SSH 服务器配置 (deploy.py 部署使用) ===
SSH_HOST=your.server.ip
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=your_ssh_password
# 更推荐使用密钥认证（二选一，密钥优先）
# SSH_KEY=~/.ssh/id_rsa
# SSH_KEY_PASSPHRASE=
REMOTE_DIR=/root/fuwuqishiyongshili

# === AI 模型 Provider 1 ===
PROVIDER1_NAME=MiniMax
PROVIDER1_API_URL=https://api.minimaxi.com/v1/chat/completions
PROVIDER1_API_KEY=sk-your-api-key
PROVIDER1_MODEL=MiniMax-M2.7-highspeed
PROVIDER1_MAX_TOKENS=4096
PROVIDER1_TEMPERATURE=0.7

# === AI 模型 Provider 2 (可选，留空则跳过) ===
PROVIDER2_NAME=
PROVIDER2_API_URL=
PROVIDER2_API_KEY=
PROVIDER2_MODEL=
PROVIDER2_MAX_TOKENS=4096
PROVIDER2_TEMPERATURE=0.7

# === AI 模型 Provider 3 (可选) ===
PROVIDER3_NAME=
PROVIDER3_API_URL=
PROVIDER3_API_KEY=
PROVIDER3_MODEL=
PROVIDER3_MAX_TOKENS=4096
PROVIDER3_TEMPERATURE=0.7

# === 服务器设置 ===
SERVER_PORT=8888
CORS_ORIGIN=https://www.hdxt.com

# === AI Agent 设置 ===
# 最大工具调用轮次（防止无限循环）
MAX_TOOL_ROUNDS=5
# 禁用 DeepSeek thinking/reasoning 模式（1=禁用加速，0=启用）
DISABLE_THINKING=1

# === 语音识别设置 (可选) ===
# 用于服务端语音转文字，留空则使用客户端识别
SPEECH_API_URL=
SPEECH_API_KEY=

# === 文件上传设置 ===
# 最大上传文件大小（字节），默认 50MB
UPLOAD_MAX_SIZE=52428800